generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  SUPPORT
  ADMIN
}

enum PasteExposure {
  PUBLIC
  UNLISTED
  PROTECTED
  PRIVATE
  SHARED
}

enum UserExposure {
  PUBLIC
  PRIVATE
}

model User {
  id               String       @id @default(cuid())
  username         String       @unique
  email            String       @unique
  description      String?
  passwordHash     String
  role             UserRole     @default(USER)
  exposure         UserExposure @default(PUBLIC)
  refreshTokenHash String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  lastActiveAt     DateTime     @default(now())
  pastes           Paste[]
  comments         Comment[]
  likes            Like[]
  userTags         UserTags[]

  @@index([createdAt])
}

model Paste {
  id           String        @id @default(uuid())
  title        String
  content      String
  description  String?
  category     String?
  language     String?
  expiresAt    DateTime?
  isBurn       Boolean       @default(false)
  passwordHash String?
  exposure     PasteExposure
  authorId     String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  author       User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments     Comment[]
  likes        Like[]
  pasteTags    PasteTags[]

  @@index([authorId])
  @@index([expiresAt])
  @@index([createdAt])
}

model Comment {
  id        String    @id @default(cuid())
  content   String?
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  authorId String
  pasteId  String
  parentId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author User  @relation(fields: [authorId], references: [id], onDelete: Cascade)
  paste  Paste @relation(fields: [pasteId], references: [id], onDelete: Cascade)

  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Restrict)
  replies Comment[] @relation("CommentReplies")

  @@index([authorId])
  @@index([pasteId])
  @@index([parentId])
  @@index([pasteId, parentId, createdAt])
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  pasteId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  paste Paste @relation(fields: [pasteId], references: [id], onDelete: Cascade)

  @@unique([userId, pasteId])
  @@index([userId])
  @@index([pasteId])
}

model UserTags {
  id        String   @id @default(cuid())
  content   String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasteTags {
  id        String   @id @default(cuid())
  content   String
  pasteId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  paste Paste @relation(fields: [pasteId], references: [id], onDelete: Cascade)
}
